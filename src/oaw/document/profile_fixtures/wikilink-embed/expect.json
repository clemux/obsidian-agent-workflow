{
  "obsidian": {
    "version": "1.12.7",
    "source": "documented",
    "observation": "`[[target]]` renders a wikilink and `![[target]]` embeds the target note (or the referenced section) inline."
  },
  "parser": {
    "obsidian_spans": [
      {
        "kind": "wikilink",
        "target": "Target Note",
        "line": 0
      },
      {
        "kind": "embed",
        "target": "Target Note#Section",
        "line": 2
      }
    ],
    "newline": "lf"
  }
}
