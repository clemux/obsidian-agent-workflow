{
  "obsidian": {
    "version": "1.12.7",
    "source": "documented",
    "observation": "Obsidian comment and math delimiter recognition does not depend on the note's line-ending convention."
  },
  "parser": {
    "obsidian_spans": [
      {
        "kind": "comment",
        "line": 0
      },
      {
        "kind": "math-inline",
        "line": 2
      },
      {
        "kind": "math-block",
        "line": 4
      }
    ],
    "newline": "crlf"
  }
}
